<?xml version="1.0" encoding="utf-8"?>
<fan.appcompat.internal.widget.DialogParentPanel xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/parentPanel"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:background="?android:attr/windowBackground"
    android:clickable="true"
    android:importantForAccessibility="no"
    android:orientation="vertical"
    android:paddingTop="@dimen/miuix_appcompat_dialog_panel_padding_vertical"
    android:paddingBottom="@dimen/miuix_appcompat_dialog_panel_padding_vertical">

    <LinearLayout
        android:id="@+id/topPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="@dimen/miuix_appcompat_dialog_panel_padding_horizontal"
        android:paddingEnd="@dimen/miuix_appcompat_dialog_panel_padding_horizontal"
        android:paddingBottom="@dimen/miuix_appcompat_dialog_title_padding_bottom">

        <ImageView
            android:id="@android:id/icon"
            android:layout_width="@dimen/miuix_appcompat_dialog_icon_drawable_width"
            android:layout_height="@dimen/miuix_appcompat_dialog_icon_drawable_height"
            android:layout_marginBottom="@dimen/miuix_appcompat_dialog_icon_drawable_margin"
            android:scaleType="fitCenter"
            android:src="@null" />

        <TextView
            android:id="@+id/alertTitle"
            style="?android:attr/windowTitleStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:ellipsize="end"
            android:maxLines="4"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:textDirection="locale" />
    </LinearLayout>

    <fan.appcompat.internal.widget.NestedScrollViewExpandContainer
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.0"
        android:overScrollMode="ifContentScrolls"
        android:scrollbars="vertical">

        <fan.appcompat.internal.widget.NestedScrollViewExpander
            android:id="@+id/contentPanel"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/contentView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/miuix_appcompat_dialog_panel_small_padding_horizontal"
                android:layout_marginEnd="@dimen/miuix_appcompat_dialog_panel_small_padding_horizontal"
                android:layout_marginBottom="@dimen/miuix_appcompat_dialog_content_margin_bottom"
                android:orientation="vertical">

                <fan.appcompat.internal.widget.TextAlignLayout
                    android:id="@+id/textAlign"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/message"
                        style="?dialogMessageTextAppearance"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textDirection="locale" />

                    <TextView
                        android:id="@+id/comment"
                        style="?attr/dialogCommentTextAppearance"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="16dp"
                        android:textDirection="locale" />
                </fan.appcompat.internal.widget.TextAlignLayout>

                <ViewStub
                    android:id="@+id/checkbox_stub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/miuix_appcompat_dialog_checkbox_margin_vertical"
                    android:layout_marginEnd="@dimen/miuix_appcompat_dialog_checkbox_margin_horizontal"
                    android:layout="@layout/miuix_appcompat_alert_dialog_checkbox" />
            </LinearLayout>

            <FrameLayout
                android:id="@android:id/custom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <include
                android:id="@+id/buttonPanel"
                layout="@layout/miuix_appcompat_alert_dialog_button_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/miuix_appcompat_dialog_button_margin_vertical" />
        </fan.appcompat.internal.widget.NestedScrollViewExpander>
    </fan.appcompat.internal.widget.NestedScrollViewExpandContainer>
</fan.appcompat.internal.widget.DialogParentPanel>
