<?xml version="1.0" encoding="utf-8"?>
<fan.appcompat.internal.view.menu.ListMenuItemView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:itemBackground="?attr/immersionViewItemBackground"
    android:minWidth="@dimen/miuix_appcompat_popup_menu_item_min_width"
    android:minHeight="@dimen/miuix_appcompat_popup_menu_item_min_height">

    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:duplicateParentState="true">

        <TextView
            android:id="@+id/title"
            style="@style/Widget.PopupMenu.MenuItem.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:duplicateParentState="true"
            android:fadingEdge="horizontal" />

        <TextView
            android:id="@+id/shortcut"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/title"
            android:layout_alignParentStart="true"
            android:duplicateParentState="true"
            android:singleLine="true"
            android:textAppearance="?android:attr/textAppearanceSmallPopupMenu" />
    </RelativeLayout>
</fan.appcompat.internal.view.menu.ListMenuItemView>
