<?xml version="1.0" encoding="utf-8"?>
<fan.appcompat.internal.app.widget.FloatingDecorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/action_bar_overlay_floating_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View
        android:id="@+id/action_bar_overlay_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FF000000"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:importantForAccessibility="no" />

    <fan.appcompat.internal.app.widget.ActionBarOverlayLayout
        android:id="@+id/action_bar_overlay_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center|top"
        android:clickable="true">

        <View
            android:id="@+id/sliding_drawer_handle"
            android:layout_width="match_parent"
            android:layout_height="@dimen/miuix_appcompat_floating_window_drag_handle_height"
            android:layout_gravity="center|top"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:importantForAccessibility="no"
            android:visibility="gone" />
    </fan.appcompat.internal.app.widget.ActionBarOverlayLayout>
</fan.appcompat.internal.app.widget.FloatingDecorLayout>
