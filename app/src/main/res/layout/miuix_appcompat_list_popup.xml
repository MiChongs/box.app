<?xml version="1.0" encoding="utf-8"?>
<fan.smooth.SmoothFrameLayout2 xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:radius="@dimen/miuix_appcompat_immersion_menu_background_radius">

    <fan.springback.view.SpringBackLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:scrollableView="@android:id/list">

        <ListView
            android:id="@android:id/list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="ifContentScrolls" />
    </fan.springback.view.SpringBackLayout>
</fan.smooth.SmoothFrameLayout2>