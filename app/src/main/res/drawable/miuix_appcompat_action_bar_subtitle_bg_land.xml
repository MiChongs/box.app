<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:bottom="13px"
        android:gravity="start"
        android:top="13px">
        <shape android:shape="rectangle">
            <solid android:color="?attr/actionBarTitleColor" />
            <size
                android:width="@dimen/miuix_appcompat_action_bar_subtitle_bg_divider_width"
                android:height="@dimen/miuix_appcompat_action_bar_subtitle_bg_divider_height" />
            <padding
                android:left="@dimen/miuix_appcompat_action_bar_subtitle_bg_start_margin"
                android:right="@dimen/miuix_appcompat_action_bar_subtitle_bg_end_margin" />
        </shape>
    </item>
</layer-list>
