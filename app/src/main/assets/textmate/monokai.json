{
    "name": "Monokai",
    "type": "dark",
    "colors": {
        "editor.background": "#00000000",
        "editor.foreground": "#F8F8F2",
        "editor.lineHighlightBackground": "#3E3D32",
        "editor.selectionBackground": "#49483E",
        "editorCursor.foreground": "#F8F8F0"
    },
    "tokenColors": [
        { "settings": { "foreground": "#F8F8F2" } },
        { "scope": ["comment", "comment.line"], "settings": { "foreground": "#75715E", "fontStyle": "italic" } },
        { "scope": ["string", "string.quoted", "string.unquoted"], "settings": { "foreground": "#E6DB74" } },
        { "scope": ["constant.numeric"], "settings": { "foreground": "#AE81FF" } },
        { "scope": ["constant.language"], "settings": { "foreground": "#AE81FF", "fontStyle": "bold" } },
        { "scope": ["constant.language.boolean.true", "constant.language.truthy"], "settings": { "foreground": "#AE81FF", "fontStyle": "bold" } },
        { "scope": ["constant.language.boolean.false", "constant.language.falsy"], "settings": { "foreground": "#AE81FF", "fontStyle": "bold" } },
        { "scope": "constant.language.null", "settings": { "foreground": "#AE81FF", "fontStyle": "bold" } },
        { "scope": ["support.type.property-name.json", "entity.name.tag", "support.type.property-name"], "settings": { "foreground": "#66D9EF" } },
        { "scope": ["punctuation.separator.dictionary.key-value.json"], "settings": { "foreground": "#F8F8F2" } },
        { "scope": ["punctuation.definition.dictionary.begin.json", "punctuation.definition.dictionary.end.json"], "settings": { "foreground": "#F8F8F2" } },
        { "scope": ["punctuation.definition.array.begin.json", "punctuation.definition.array.end.json"], "settings": { "foreground": "#F8F8F2" } },
        { "scope": "entity.name.tag.yaml", "settings": { "foreground": "#F92672", "fontStyle": "bold" } },
        { "scope": ["keyword.control.flow.block-scalar.literal.yaml", "keyword.control.flow.block-scalar.folded.yaml"], "settings": { "foreground": "#F92672", "fontStyle": "bold" } },
        { "scope": ["variable.other.anchor", "variable.other.alias"], "settings": { "foreground": "#AE81FF", "fontStyle": "bold" } },
        { "scope": "variable.other.substitution", "settings": { "foreground": "#E6DB74" } },
        { "scope": "punctuation.definition.block.sequence.item.yaml", "settings": { "foreground": "#F92672" } },
        { "scope": ["entity.other.document.begin.yaml", "entity.other.document.end.yaml"], "settings": { "foreground": "#75715E", "fontStyle": "bold" } },
        { "scope": "storage.type.tag-handle.yaml", "settings": { "foreground": "#66D9EF" } },
        { "scope": ["entity.name.section", "entity.name.section.ini"], "settings": { "foreground": "#A6E22E", "fontStyle": "bold" } },
        { "scope": ["punctuation.separator", "punctuation.separator.key-value"], "settings": { "foreground": "#F92672" } },
        { "scope": "constant.character.escape", "settings": { "foreground": "#AE81FF", "fontStyle": "bold" } },
        { "scope": "constant.other.ip-address", "settings": { "foreground": "#AE81FF", "fontStyle": "bold" } },
        { "scope": ["string.other.url", "markup.underline.link"], "settings": { "foreground": "#66D9EF", "fontStyle": "underline" } },
        { "scope": "string.other.path", "settings": { "foreground": "#E6DB74" } },
        { "scope": "invalid.illegal", "settings": { "foreground": "#F44747", "fontStyle": "bold" } },
        { "scope": "meta.directive", "settings": { "foreground": "#A6E22E" } }
    ]
}
