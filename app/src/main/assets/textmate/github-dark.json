{
    "name": "GitHub Dark",
    "type": "dark",
    "colors": {
        "editor.background": "#00000000",
        "editor.foreground": "#E6EDF3",
        "editor.lineHighlightBackground": "#161B22",
        "editor.selectionBackground": "#264F78",
        "editorCursor.foreground": "#E6EDF3"
    },
    "tokenColors": [
        { "settings": { "foreground": "#E6EDF3" } },
        { "scope": ["comment", "comment.line"], "settings": { "foreground": "#8B949E", "fontStyle": "italic" } },
        { "scope": ["string", "string.quoted", "string.unquoted"], "settings": { "foreground": "#A5D6FF" } },
        { "scope": ["constant.numeric"], "settings": { "foreground": "#79C0FF" } },
        { "scope": ["constant.language"], "settings": { "foreground": "#79C0FF", "fontStyle": "bold" } },
        { "scope": ["constant.language.boolean.true", "constant.language.truthy"], "settings": { "foreground": "#79C0FF", "fontStyle": "bold" } },
        { "scope": ["constant.language.boolean.false", "constant.language.falsy"], "settings": { "foreground": "#FF7B72", "fontStyle": "bold" } },
        { "scope": "constant.language.null", "settings": { "foreground": "#79C0FF", "fontStyle": "bold" } },
        { "scope": ["support.type.property-name.json", "entity.name.tag", "support.type.property-name"], "settings": { "foreground": "#7EE787" } },
        { "scope": ["punctuation.separator.dictionary.key-value.json"], "settings": { "foreground": "#E6EDF3" } },
        { "scope": ["punctuation.definition.dictionary.begin.json", "punctuation.definition.dictionary.end.json"], "settings": { "foreground": "#E6EDF3" } },
        { "scope": ["punctuation.definition.array.begin.json", "punctuation.definition.array.end.json"], "settings": { "foreground": "#E6EDF3" } },
        { "scope": "entity.name.tag.yaml", "settings": { "foreground": "#7EE787", "fontStyle": "bold" } },
        { "scope": ["keyword.control.flow.block-scalar.literal.yaml", "keyword.control.flow.block-scalar.folded.yaml"], "settings": { "foreground": "#FF7B72", "fontStyle": "bold" } },
        { "scope": ["variable.other.anchor", "variable.other.alias"], "settings": { "foreground": "#FFA657", "fontStyle": "bold" } },
        { "scope": "variable.other.substitution", "settings": { "foreground": "#FFA657" } },
        { "scope": "punctuation.definition.block.sequence.item.yaml", "settings": { "foreground": "#FF7B72" } },
        { "scope": ["entity.other.document.begin.yaml", "entity.other.document.end.yaml"], "settings": { "foreground": "#8B949E", "fontStyle": "bold" } },
        { "scope": "storage.type.tag-handle.yaml", "settings": { "foreground": "#D2A8FF" } },
        { "scope": ["entity.name.section", "entity.name.section.ini"], "settings": { "foreground": "#FFA657", "fontStyle": "bold" } },
        { "scope": ["punctuation.separator", "punctuation.separator.key-value"], "settings": { "foreground": "#FF7B72" } },
        { "scope": "constant.character.escape", "settings": { "foreground": "#79C0FF", "fontStyle": "bold" } },
        { "scope": "constant.other.ip-address", "settings": { "foreground": "#79C0FF", "fontStyle": "bold" } },
        { "scope": ["string.other.url", "markup.underline.link"], "settings": { "foreground": "#A5D6FF", "fontStyle": "underline" } },
        { "scope": "string.other.path", "settings": { "foreground": "#A5D6FF" } },
        { "scope": "invalid.illegal", "settings": { "foreground": "#FF7B72", "fontStyle": "bold" } },
        { "scope": "meta.directive", "settings": { "foreground": "#D2A8FF" } }
    ]
}
