{
    "name": "One Dark",
    "type": "dark",
    "colors": {
        "editor.background": "#00000000",
        "editor.foreground": "#ABB2BF",
        "editor.lineHighlightBackground": "#2C313C",
        "editor.selectionBackground": "#3E4451",
        "editorCursor.foreground": "#528BFF"
    },
    "tokenColors": [
        { "settings": { "foreground": "#ABB2BF" } },
        { "scope": ["comment", "comment.line"], "settings": { "foreground": "#5C6370", "fontStyle": "italic" } },
        { "scope": ["string", "string.quoted", "string.unquoted"], "settings": { "foreground": "#98C379" } },
        { "scope": ["constant.numeric"], "settings": { "foreground": "#D19A66" } },
        { "scope": ["constant.language"], "settings": { "foreground": "#D19A66", "fontStyle": "bold" } },
        { "scope": ["constant.language.boolean.true", "constant.language.truthy"], "settings": { "foreground": "#D19A66", "fontStyle": "bold" } },
        { "scope": ["constant.language.boolean.false", "constant.language.falsy"], "settings": { "foreground": "#D19A66", "fontStyle": "bold" } },
        { "scope": "constant.language.null", "settings": { "foreground": "#D19A66", "fontStyle": "bold" } },
        { "scope": ["support.type.property-name.json", "entity.name.tag", "support.type.property-name"], "settings": { "foreground": "#E06C75" } },
        { "scope": ["punctuation.separator.dictionary.key-value.json"], "settings": { "foreground": "#ABB2BF" } },
        { "scope": ["punctuation.definition.dictionary.begin.json", "punctuation.definition.dictionary.end.json"], "settings": { "foreground": "#ABB2BF" } },
        { "scope": ["punctuation.definition.array.begin.json", "punctuation.definition.array.end.json"], "settings": { "foreground": "#ABB2BF" } },
        { "scope": "entity.name.tag.yaml", "settings": { "foreground": "#E06C75", "fontStyle": "bold" } },
        { "scope": ["keyword.control.flow.block-scalar.literal.yaml", "keyword.control.flow.block-scalar.folded.yaml"], "settings": { "foreground": "#C678DD", "fontStyle": "bold" } },
        { "scope": ["variable.other.anchor", "variable.other.alias"], "settings": { "foreground": "#E5C07B", "fontStyle": "bold" } },
        { "scope": "variable.other.substitution", "settings": { "foreground": "#E5C07B" } },
        { "scope": "punctuation.definition.block.sequence.item.yaml", "settings": { "foreground": "#C678DD" } },
        { "scope": ["entity.other.document.begin.yaml", "entity.other.document.end.yaml"], "settings": { "foreground": "#5C6370", "fontStyle": "bold" } },
        { "scope": "storage.type.tag-handle.yaml", "settings": { "foreground": "#56B6C2" } },
        { "scope": ["entity.name.section", "entity.name.section.ini"], "settings": { "foreground": "#E5C07B", "fontStyle": "bold" } },
        { "scope": ["punctuation.separator", "punctuation.separator.key-value"], "settings": { "foreground": "#C678DD" } },
        { "scope": "constant.character.escape", "settings": { "foreground": "#56B6C2", "fontStyle": "bold" } },
        { "scope": "constant.other.ip-address", "settings": { "foreground": "#56B6C2", "fontStyle": "bold" } },
        { "scope": ["string.other.url", "markup.underline.link"], "settings": { "foreground": "#61AFEF", "fontStyle": "underline" } },
        { "scope": "string.other.path", "settings": { "foreground": "#98C379" } },
        { "scope": "invalid.illegal", "settings": { "foreground": "#FF0000", "fontStyle": "bold" } },
        { "scope": "meta.directive", "settings": { "foreground": "#C678DD" } }
    ]
}
