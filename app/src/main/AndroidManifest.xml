<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-sdk tools:overrideLibrary="top.yukonga.miuix.kmp.blur,fan.animation,fan.appcompat,fan.basewidget,fan.bottomsheet,fan.cardview,fan.core,fan.flexible,fan.folme,fan.graphics,fan.haptic,fan.navigator,fan.nestedheader,fan.pickerwidget,fan.popupwidget,fan.preference,fan.recyclerview,fan.slidingwidget,fan.smooth,fan.springback,fan.stretchablewidget,fan.theme,fan.transition,fan.viewpager,fan.viewpager2" />

    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />
    <!-- 国产 ROM（MIUI/HyperOS/ColorOS/OriginOS）"获取应用列表"权限 -->
    <uses-permission android:name="com.android.permission.GET_INSTALLED_APPS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission
        android:name="android.permission.NEARBY_WIFI_DEVICES"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:usesCleartextTraffic="true"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:name=".AppApplication"
        android:theme="@style/Theme.BoxReApp">

        <activity
            android:name=".MainActivity"
            android:enableOnBackInvokedCallback="true"
            android:windowSoftInputMode="adjustResize"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".qs.TileLongPressActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE_PREFERENCES" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <service
            android:name=".qs.ServiceTileService"
            android:exported="true"
            android:icon="@drawable/ic_qs_box"
            android:label="@string/qs_tile_service_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
            <meta-data
                android:name="android.service.quicksettings.ACTIVE_TILE"
                android:value="false" />
        </service>

        <service
            android:name=".service.BoxForegroundService"
            android:exported="false"
            android:stopWithTask="false"
            android:foregroundServiceType="connectedDevice" />

        <receiver
            android:name=".service.ServiceRestartReceiver"
            android:exported="false" />

        <!-- Provision OOBE Activities -->
        <activity
            android:name=".provision.activity.DefaultActivity"
            android:exported="false"
            android:theme="@style/ProvisionTheme" />
        <activity
            android:name=".provision.activity.PermissionSettingsActivity"
            android:exported="false"
            android:theme="@style/ProvisionTheme" />
        <activity
            android:name=".provision.activity.TermsAndStatementActivity"
            android:exported="false"
            android:theme="@style/ProvisionTheme" />
        <activity
            android:name=".provision.activity.BasicSettingsActivity"
            android:exported="false"
            android:theme="@style/ProvisionTheme" />
        <activity
            android:name=".provision.activity.CongratulationActivity"
            android:exported="false"
            android:theme="@style/ProvisionTheme" />

        <service
            android:name=".provision.service.ProvisionAnimService"
            android:exported="false" />

    </application>

</manifest>
